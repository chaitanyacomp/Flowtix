# Copy to .env and adjust. MySQL must be running (e.g. docker compose up -d mysql).
DATABASE_URL="mysql://erp:erp123@localhost:3306/mini_erp"
PORT=4000
# Optional in development; defaults to a dev secret if unset (not for production).
JWT_SECRET=

# When true, RM Purchase allows temporary HSN/GST/unit fallbacks for incomplete masters (testing only).
# TESTING_MODE_RELAXED_TAX_FIELDS=true

# Integration tests: empty DB + prisma db push (see docs/INTEGRATION_TEST_DB.md).
# INTEGRATION_DATABASE_URL="mysql://erp:erp1234@localhost:3306/mini_erp_integration"

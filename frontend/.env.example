# Optional: base URL of the backend (scheme + host + port only).
# Do NOT add /api — request paths already include /api (e.g. /api/auth/login).
#
# Development (default): leave unset to use the Vite dev server proxy
# (browser calls /api/... on port 5173 → forwarded to http://127.0.0.1:4000).
#
# Direct to backend (bypass proxy), e.g. if the proxy misbehaves:
# VITE_API_URL=http://127.0.0.1:4000
#
# If you previously used http://127.0.0.1:4000/api — that is wrong and caused
# /api/api/... URLs; the app now strips a trailing /api automatically.

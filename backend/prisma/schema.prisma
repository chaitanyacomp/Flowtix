// Mini ERP — multi-line manufacturing model

generator client {
  provider = "prisma-client-js"
  /// Outside node_modules/.prisma so `prisma generate` succeeds when query_engine DLL is locked on Windows.
  output   = "./generated/client-v2"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STORE
  PURCHASE
  PRODUCTION
  QA
}

/// ERP-side payment tracking only (not double-entry / ledger posting).
enum BillPaymentTrackingStatus {
  PENDING
  PARTIAL
  PAID
}

/// ERP receipt/payment line mode — commercial tracking only (not bank ledger).
enum CommercialPaymentMode {
  CASH
  BANK
  UPI
  CHEQUE
  OTHER
}

/// Phase 1 audit trail — see services/auditLog.js
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CANCEL
  REVERSE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  BLOCKED_DELETE
}

enum AuditEntityType {
  ITEM
  CUSTOMER
  SUPPLIER
  BOM
  SALES_ORDER
  WORK_ORDER
  PRODUCTION_ENTRY
  QC_ENTRY
  DISPATCH
  STOCK_ADJUSTMENT
  CUSTOMER_RETURN
  USER
  SETTINGS
  USER_SESSION
}

/// Local DB backup file metadata (Phase 1: disk + mysqldump only).
enum DbBackupType {
  MANUAL
  PRE_RESTORE_AUTO
}

enum DbBackupStatus {
  CREATED
  FAILED
  RESTORED
}

/// Canonical document types for ERP numbering (docNo).
enum DocType {
  SALES_ORDER
  WORK_ORDER
  PRODUCTION_ENTRY
  QC_ENTRY
  DISPATCH
  SALES_BILL
  REQUIREMENT_SHEET
  MATERIAL_REQUIREMENT
  PURCHASE_REQUEST
  MATERIAL_ISSUE_NOTE
  MATERIAL_RETURN_NOTE
  MATERIAL_WASTAGE_NOTE
  PRODUCTION_MATERIAL_REQUEST
  BOM
  MONTHLY_PRODUCTION_PLAN
}

/// RM declared as process loss / scrap at production (MWN) — not returned to store.
enum RmWastageReason {
  PROCESS_LOSS
  MACHINE_SETTING
  SPILLAGE
  CONTAMINATION
  PURGING
  OTHER
}

/// Production → Store RM request (PMR); fulfilled via Material Issue Note (MIN).
enum ProductionMaterialRequestStatus {
  DRAFT
  REQUESTED
  PARTIALLY_ISSUED
  FULLY_ISSUED
  CANCELLED
}

enum MaterialAllocationStatus {
  ACTIVE
  PARTIALLY_ISSUED
  ISSUED
  RELEASED
  CANCELLED
}

enum MaterialAllocationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MaterialAllocationType {
  PMR_CREATED
  MANUAL
  SYSTEM_MIGRATED
}

/// Store → Purchase handoff (consolidated RM requirement; not an RM PO).
enum PurchaseRequestStatus {
  PENDING_PURCHASE
  PARTIALLY_ORDERED
  ORDERED
  CANCELLED
}

/// Operational BOM classification (manufacturing planning, not accounting).
enum BomType {
  STANDARD
  APPROXIMATE
  CUSTOMER_SPECIFIC
}

enum BomStatus {
  DRAFT
  APPROVED
  INACTIVE
  ARCHIVED
}

enum BomNormalizationMode {
  PER_PIECE
  LEGACY_BATCH
}

enum SimpleStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  /// REGULAR WO: operational hold (RM shortage, management, etc.).
  HOLD
  /// REGULAR WO: intentional production pause after partial QC; FG kept for originating SO.
  PAUSED
  /// REGULAR WO: management closed remaining balance; shortfallQty records unreleased plan.
  CLOSED_WITH_SHORTFALL
}

/// REGULAR work order hold reason (operational pause).
enum WoHoldReason {
  RM_SHORTAGE
  MACHINE_BREAKDOWN
  PRIORITY_SHIFT
  CUSTOMER_HOLD
  MANAGEMENT_HOLD
  /// Partial production + QC accepted; user chose to keep stock and pause WO.
  PRODUCTION_PAUSE
  OTHER
}

/// No Qty SO internal workflow cycles (reopen creates a new active cycle; history is locked per cycle).
enum SalesOrderCycleStatus {
  ACTIVE
  CLOSED
}

/// Raw material purchase order lifecycle (GRN-driven).
enum RmPoStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

/// GRN purchase-billing lifecycle (Tally-facing supplier invoice; no stock impact).
enum GrnBillingStatus {
  PENDING
  BILLED
}

enum PurchaseBillStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum SalesBillStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum EnquiryStatus {
  DRAFT
  OPEN
  PENDING
  FEASIBLE
  NOT_FEASIBLE
  QUOTED
  PO_RECEIVED
  CLOSED
}

enum EnquiryFlowType {
  REGULAR
  NO_QTY
}

enum QuotationWorkflowStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum SalesOrderInternalStatus {
  DRAFT
  OPEN
  APPROVED
  IN_PROCESS
  COMPLETED
  CLOSED
  MANUALLY_CLOSED
}

enum SalesOrderType {
  NORMAL
  REPLACEMENT
  NO_QTY
}

enum ItemType {
  RM
  FG
  /// Semi-finished — may have its own child BOM (components for parent FG BOM).
  SFG
  /// Future-ready; not required for Phase 2 operations.
  CONSUMABLE
}

enum StockTxnType {
  /// One-time system initialization: opening stock posted after explicit approval.
  OPENING
  /// Offset for OPENING (qtyOut from same bucket; reversalOfId → forward OPENING stock row).
  OPENING_REVERSAL
  GRN
  ISSUE
  PRODUCTION
  QC
  DISPATCH
  SCRAP
  ADJUSTMENT
  /// Internal stock bucket movement (e.g. QC_HOLD→REWORK, REWORK→QC_PENDING, bucket transfers). Not a user "adjustment".
  BUCKET_TRANSFER
  /// Store → Production location transfer (paired qtyOut / qtyIn rows). Not production BOM consumption (see ISSUE).
  LOCATION_TRANSFER
  DISPATCH_REVERSAL
  QC_REVERSAL
  CUSTOMER_RETURN
  /// Production-location RM written off as wastage (MWN). qtyOut only — final loss, not reusable stock.
  RM_WASTAGE
}

enum OpeningStockStatus {
  DRAFT
  APPROVED
}

enum StockBucket {
  USABLE
  QC_HOLD
  /// Awaiting QC re-check after internal rework (Stock → Send to QC). Not “Hold for Checking”.
  QC_PENDING
  REWORK
  /// Non-dispatchable loss bucket (QC rejects directed to scrap).
  SCRAP
}

/// Physical / process stock location (separate from StockBucket quality state).
enum LocationType {
  RM_STORE
  PRODUCTION
  FG_STORE
  WIP
  SCRAP
  VENDOR
  CONSUMABLE
  DISPATCH
}

enum LocationDepartment {
  STORES
  PRODUCTION
  PURCHASE
  PLANT_HEAD
}

/// Operator intent for rejected quantity on a QC posting (stock bucket may match QC_HOLD for both Rework and Hold).
enum QcRejectedRoute {
  REWORK
  HOLD
  SCRAP
  USABLE
}

enum QcRejectedDispositionStatus {
  REWORK_PENDING_SUPERVISOR
  /// Supervisor approved rework, but rework is not yet executed. Not QC-ready.
  REWORK_APPROVED_PENDING_EXECUTION
  REWORK_READY_FOR_QC
  HOLD
  SCRAP
  CLOSED
}

enum QcRejectedPhase {
  FIRST_QC
  RECHECK
}

/// One-time closure for pre–new-flow production QC rejects (does not edit QcEntry accepted/rejected fields).
enum QcLegacyRejectedAction {
  APPROVE_TO_USABLE
  MOVE_TO_HOLD
  SCRAP
}

/// Production batch lifecycle: DRAFT (editable, no RM issue, not QC-eligible) → APPROVED (locked, RM issued, QC-eligible).
enum ProductionEntryWorkflowStatus {
  DRAFT
  APPROVED
}

/// Operator-classified RM consumption variance on production approval (REGULAR only).
enum RmConsumptionType {
  NORMAL
  EXTRA_PROCESS_LOSS
  LOWER_USAGE
  REWORK_RESERVED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  idempotencyRecords                       IdempotencyRecord[]
  stockTxnsCreated                         StockTransaction[]               @relation("StockTxnCreatedBy")
  stockTxnsReversed                        StockTransaction[]               @relation("StockTxnReversedBy")
  stockTxnsApproved                        StockTransaction[]               @relation("StockTxnApprovedBy")
  openingStockEntriesCreated               OpeningStockEntry[]              @relation("OpeningStockCreatedBy")
  openingStockEntriesApproved              OpeningStockEntry[]              @relation("OpeningStockApprovedBy")
  workOrdersFgStockOverride                WorkOrder[]                      @relation("WoFgStockOverrideBy")
  workOrdersHeld                           WorkOrder[]                      @relation("WoHeldBy")
  workOrdersClosedShortfall                WorkOrder[]                      @relation("WoClosedBy")
  regularSoPlanningSnapshotsCreated        RegularSoPlanningSnapshot[]      @relation("RegularSoPlanningSnapshotCreatedBy")
  regularSoPlanningSnapshotsUpdated        RegularSoPlanningSnapshot[]      @relation("RegularSoPlanningSnapshotUpdatedBy")
  reopenedSalesOrderCycles                 SalesOrderCycle[]                @relation("SalesOrderCycleReopenedBy")
  quotationsApprovalCancelled              Quotation[]                      @relation("QuotationApprovalCancelledBy")
  purchaseBillsExportReset                 PurchaseBill[]                   @relation("PurchaseBillExportResetBy")
  purchaseBillsCancelled                   PurchaseBill[]                   @relation("PurchaseBillCancelledBy")
  salesBillsFinalized                      SalesBill[]                      @relation("SalesBillFinalizedBy")
  salesBillsCancelled                      SalesBill[]                      @relation("SalesBillCancelledBy")
  salesBillsExportReset                    SalesBill[]                      @relation("SalesBillExportResetBy")
  salesBillsExported                       SalesBill[]                      @relation("SalesBillExportedBy")
  auditLogs                                AuditLog[]                       @relation("AuditLogActor")
  activityLogs                             ActivityLog[]                    @relation("ActivityLogActor")
  qcRejectedDispositionsCreated            QcRejectedDisposition[]          @relation("QcRejDispCreatedBy")
  qcRejectedDispositionsSupervisorApproved QcRejectedDisposition[]          @relation("QcRejDispSupervisorApproved")
  qcLegacyRejectedClassifications          QcLegacyRejectedClassification[]
  noQtySoCloseSnapshotsClosed             NoQtySoCloseSnapshot[]          @relation("NoQtySoCloseSnapshotClosedBy")
  noQtySoCloseSnapshotsReopened           NoQtySoCloseSnapshot[]          @relation("NoQtySoCloseSnapshotReopenedBy")
  salesBillReceiptsCreated                SalesBillReceipt[]              @relation("SalesBillReceiptCreatedBy")
  purchaseBillPaymentsCreated             PurchaseBillPayment[]           @relation("PurchaseBillPaymentCreatedBy")
  dbBackupsCreated                        DbBackup[]                      @relation("DbBackupCreatedBy")
  rateContractLinesCreated                RateContractLine[]              @relation("RateContractLineCreatedBy")
  rateContractLinesDeactivated            RateContractLine[]              @relation("RateContractLineDeactivatedBy")
  materialRequirementsCreated             MaterialRequirement[]           @relation("MaterialRequirementCreatedBy")
  materialRequirementsReversed            MaterialRequirement[]           @relation("MaterialRequirementReversedBy")
  materialRequirementsRaised              MaterialRequirement[]           @relation("MaterialRequirementRaisedBy")
  materialRequirementsApproved            MaterialRequirement[]           @relation("MaterialRequirementApprovedBy")
  purchaseRequestsCreated                 PurchaseRequest[]               @relation("PurchaseRequestCreatedBy")
  materialIssueNotesCreated               MaterialIssueNote[]             @relation("MaterialIssueCreatedBy")
  materialReturnNotesCreated               MaterialReturnNote[]            @relation("MaterialReturnCreatedBy")
  materialWastageNotesCreated              MaterialWastageNote[]           @relation("MaterialWastageCreatedBy")
  productionMaterialRequestsCreated       ProductionMaterialRequest[]     @relation("PmrCreatedBy")
  productionMaterialRequestsRequested     ProductionMaterialRequest[]     @relation("PmrRequestedBy")
  materialAllocationsCreated              MaterialAllocation[]            @relation("MaterialAllocationCreatedBy")
  materialAllocationsReleased             MaterialAllocation[]            @relation("MaterialAllocationReleasedBy")
  monthlyProductionPlansCreated           MonthlyProductionPlan[]         @relation("MppCreatedBy")
  monthlyProductionPlansLocked            MonthlyProductionPlan[]         @relation("MppLockedBy")
  monthlyProductionPlansReopened          MonthlyProductionPlan[]         @relation("MppReopenedBy")
  monthlyProductionPlansReleased          MonthlyProductionPlan[]         @relation("MppReleasedBy")
  monthlyProductionPlansPurchaseReviewed  MonthlyProductionPlan[]         @relation("MppPurchaseReviewedBy")
  monthlyProductionPlansApproved          MonthlyProductionPlan[]         @relation("MppApprovedBy")
  rmPlansRecalculated                     RmPlan[]                        @relation("RmPlanRecalcBy")
}

/// Full-database SQL backup row (see admin backup routes). `filePath` is server-only; never return to clients.
model DbBackup {
  id              Int            @id @default(autoincrement())
  fileName        String         @db.VarChar(255)
  filePath        String         @db.VarChar(1024)
  fileSizeBytes   BigInt?
  backupType      DbBackupType
  status          DbBackupStatus
  createdByUserId Int
  createdAt       DateTime       @default(now())
  restoredAt      DateTime?
  remarks         String?        @db.Text

  createdBy User @relation("DbBackupCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([backupType, status])
}

/// Cached successful responses for Idempotency-Key on critical POST routes (dispatch, etc.).
model IdempotencyRecord {
  id              Int      @id @default(autoincrement())
  userId          Int
  routeKey        String   @db.VarChar(64)
  idempotencyKey  String   @db.VarChar(255)
  requestBodyHash String   @db.VarChar(64)
  responseStatus  Int?
  responseBody    String?  @db.Text
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, routeKey, idempotencyKey])
  @@index([expiresAt])
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  email     String?
  address   String?
  /// Supplier GSTIN (Tally-compatible); same column, UI label GSTIN.
  gst       String?
  /// State / UT name or code — free text for now; used later for GST place-of-supply logic.
  state     String?  @db.VarChar(128)
  /// New (static master validated) supplier state name for GST split. Nullable for existing suppliers.
  stateName String?  @db.VarChar(128)
  /// New (static master validated) supplier GST state code (2-digit). Nullable for existing suppliers.
  stateCode String?  @db.VarChar(2)
  /// Structured state reference (GST code mapping). Nullable for backward compatibility.
  stateId   Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stateRef State? @relation(fields: [stateId], references: [id], onDelete: SetNull)

  rmPurchaseOrders RmPurchaseOrder[]
  customerPOs      CustomerPO[]
  purchaseBills    PurchaseBill[]
  grns             Grn[]
  locations        SupplierLocation[]

  @@index([stateId])
  @@index([stateCode])
  @@index([gst])
  @@index([isActive])
}

model SupplierLocation {
  id            Int      @id @default(autoincrement())
  supplierId    Int
  label         String   @db.VarChar(128)
  address       String?  @db.Text
  city          String?  @db.VarChar(128)
  stateId       Int?
  /// Optional GSTIN for this supply location (Tally branch / depot GST).
  gst           String?  @db.VarChar(15)
  contactPerson String?  @db.VarChar(128)
  phone         String?  @db.VarChar(32)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  stateRef State?   @relation(fields: [stateId], references: [id], onDelete: SetNull)

  rmPurchaseOrders RmPurchaseOrder[]
  grns             Grn[]

  @@index([supplierId])
  @@index([stateId])
  @@index([gst])
  @@index([isDefault])
  @@index([isActive])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  email     String?
  address   String?
  /// Customer GSTIN (Tally-compatible); same column, UI label GSTIN.
  gst       String?
  /// State / UT — free text for now; used later for sales GST / place of supply.
  state     String?  @db.VarChar(128)
  /// Structured state reference (GST code mapping). Nullable for backward compatibility.
  stateId   Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stateRef State? @relation(fields: [stateId], references: [id], onDelete: SetNull)

  enquiries         Enquiry[]
  pos               CustomerPO[]
  salesOrders       SalesOrder[]
  rateContractLines RateContractLine[]
  customerReturns   CustomerReturn[]
  salesBills        SalesBill[]
  deliveryAddresses CustomerDeliveryAddress[]

  @@index([stateId])
  @@index([gst])
  @@index([isActive])
}

model CustomerDeliveryAddress {
  id            Int      @id @default(autoincrement())
  customerId    Int
  label         String   @db.VarChar(128)
  address       String?  @db.Text
  city          String?  @db.VarChar(128)
  stateId       Int?
  /// Optional GSTIN for this delivery location (Tally ship-to / branch GST).
  gst           String?  @db.VarChar(15)
  contactPerson String?  @db.VarChar(128)
  phone         String?  @db.VarChar(32)
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stateRef State?   @relation(fields: [stateId], references: [id], onDelete: SetNull)
  shipToSalesOrders SalesOrder[]

  @@index([customerId])
  @@index([stateId])
  @@index([gst])
  @@index([isDefault])
  @@index([isActive])
}

model Item {
  id                                Int      @id @default(autoincrement())
  itemName                          String
  itemType                          ItemType
  /// Legacy unit text (kept for backward compatibility during Unit master rollout).
  unit                              String
  /// Structured unit reference (nullable for backward compatibility).
  unitId                            Int?
  minStockLevel                     Decimal  @default(0) @db.Decimal(18, 3)
  /// HSN / SAC code (optional until masters are complete).
  hsnCode                           String?  @db.VarChar(32)
  /// GST rate percentage (e.g. 18). No IGST/CGST/SGST split stored here.
  gstRate                           Decimal? @db.Decimal(5, 2)
  /// Legacy planning gap thresholds (gap% = shortage / requirement × 100). Used for order-wise / requirement sheets.
  /// Misnamed: `planningGapGreenThresholdPercent` is the **red** boundary (min gap% for red); yellow is min gap% for yellow.
  /// If null, services use defaults (50% / 30%). See `planningThresholds.js`.
  planningGapGreenThresholdPercent  Decimal? @db.Decimal(5, 2)
  planningGapYellowThresholdPercent Decimal? @db.Decimal(5, 2)
  /// Product-wise planning thresholds (gap% based). If null, fall back to legacy thresholds or defaults.
  redThresholdPercent               Decimal? @db.Decimal(5, 2)
  yellowThresholdPercent            Decimal? @db.Decimal(5, 2)
  /// Optional buffer applied on requirement when suggesting WO (percentage).
  planningBufferPercent             Decimal? @db.Decimal(5, 2)
  /// Optional minimum stock to maintain (absolute qty). Used as a floor for requirement in product-wise planning.
  minimumStockQty                   Decimal? @db.Decimal(18, 3)
  /// Optional reorder quantity (future use).
  reorderQty                        Decimal? @db.Decimal(18, 3)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  unitRef Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  bomsAsFg                        Bom[]                            @relation("BomFgItem")
  bomLinesAsRm                    BomLine[]                        @relation("BomLineRmItem")
  enquiryLines                    EnquiryLine[]
  quotationLines                  QuotationLine[]
  rateContractLines               RateContractLine[]
  poLines                         CustomerPOLine[]
  soLines                         SalesOrderLine[]
  rmPoLines                       RmPurchaseOrderLine[]
  workOrderLines                  WorkOrderLine[]                  @relation("WoLineFg")
  materialRequirementsAsFg        MaterialRequirement[]            @relation("MaterialRequirementFgItem")
  salesBillLines                  SalesBillLine[]
  requirementSheetLines           RequirementSheetLine[]
  materialRequirementLines        MaterialRequirementLine[]
  purchaseRequestLines            PurchaseRequestLine[]
  materialIssueLines              MaterialIssueLine[]
  materialReturnLines             MaterialReturnLine[]
  materialWastageNotes            MaterialWastageNote[]
  productionEntryRmConsumptions   ProductionEntryRmConsumption[]
  pmrLines                        ProductionMaterialRequestLine[]
  materialAllocations             MaterialAllocation[]            @relation("MaterialAllocationRmItem")
  noQtyClosedShortageLines        NoQtySoClosedShortageLine[]
  scrapRecords                    ScrapRecord[]                    @relation("ScrapFgItem")
  dispatches                      Dispatch[]
  stockTxns                       StockTransaction[]
  stockAdjustmentQcEntries        StockAdjustmentQcEntry[]
  customerReturns                 CustomerReturn[]
  purchaseBillLines               PurchaseBillLine[]
  qcRejectedDispositions          QcRejectedDisposition[]
  qcLegacyRejectedClassifications QcLegacyRejectedClassification[]
  openingStockEntries             OpeningStockEntry[]
  monthlyProductionPlanLinesAsFg  MonthlyProductionPlanLine[]      @relation("MppLineFgItem")
  monthlyProductionPlanRevisionLinesAsFg MonthlyProductionPlanRevisionLine[] @relation("MppRevisionLineFgItem")
  rmPlanLinesAsRm                 RmPlanLine[]                     @relation("RmPlanLineRmItem")

  @@index([itemType])
  @@index([unitId])
}

model Unit {
  id        Int      @id @default(autoincrement())
  unitName  String   @db.VarChar(64)
  /// Optional short code for Tally / exports (kept simple).
  unitCode  String?  @db.VarChar(16)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        Item[]
  bomsFgWeight Bom[]  @relation("BomFgWeightUnit")

  @@unique([unitName])
  @@unique([unitCode])
  @@index([isActive])
}

model Bom {
  id        Int      @id @default(autoincrement())
  fgItemId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// ERP document number (e.g. BOM-26-0001); shared across revisions.
  docNo String? @db.VarChar(32)

  bomType       BomType   @default(STANDARD)
  status        BomStatus @default(DRAFT)
  normalizationMode BomNormalizationMode @default(PER_PIECE)
  revisionNo    Int       @default(1)
  effectiveFrom DateTime? @db.Date
  remarks       String?   @db.VarChar(500)
  approvedAt    DateTime?

  /// Approved BOMs are locked; edits require admin password (see routes/boms.js).
  isLocked Boolean   @default(false)
  lockedAt DateTime?

  /// Finished-good net weight for one BOM output batch (manufacturing planning).
  fgWeight         Decimal? @db.Decimal(18, 4)
  fgWeightUnitId   Int?
  /// Number of FG units this BOM represents (default 1 Nos).
  outputQty            Decimal @default(1) @db.Decimal(18, 3)
  /// Centralized expected production + QC losses (not per RM line).
  processLossPercent   Decimal @default(0) @db.Decimal(18, 3)
  qcLossPercent        Decimal @default(0) @db.Decimal(18, 3)
  /// Optional default FG planning buffer % suggested at Prepare WO (not mandatory).
  suggestedFgPlanningBufferPercent Decimal? @db.Decimal(5, 2)

  fgItem       Item  @relation("BomFgItem", fields: [fgItemId], references: [id], onDelete: Cascade)
  fgWeightUnit Unit? @relation("BomFgWeightUnit", fields: [fgWeightUnitId], references: [id], onDelete: SetNull)
  lines        BomLine[]

  @@unique([fgItemId, revisionNo])
  @@index([fgItemId])
  @@index([docNo])
  @@index([fgWeightUnitId])
  @@index([status])
  @@index([bomType])
}

model BomLine {
  id             Int     @id @default(autoincrement())
  bomId          Int
  rmItemId       Int
  /// Per unit of FG, before wastage
  baseQty            Decimal @db.Decimal(18, 6)
  /// Legacy operational compatibility field. Currently mirrors processLossPercent for RM issue math.
  wastagePercent     Decimal @default(0) @db.Decimal(18, 3)
  processLossPercent Decimal @default(0) @db.Decimal(18, 3)
  qcAllowancePercent Decimal @default(0) @db.Decimal(18, 3)
  notes              String?

  bom    Bom  @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rmItem Item @relation("BomLineRmItem", fields: [rmItemId], references: [id], onDelete: Restrict)

  @@unique([bomId, rmItemId])
  @@index([rmItemId])
}

model Enquiry {
  id         Int           @id @default(autoincrement())
  customerId Int
  status     EnquiryStatus @default(PENDING)
  flowType   EnquiryFlowType @default(REGULAR)
  remarks    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines       EnquiryLine[]
  feasibility Feasibility?
  quotation   Quotation?

  @@index([customerId])
  @@index([status])
  @@index([flowType])
}

model EnquiryLine {
  id        Int     @id @default(autoincrement())
  enquiryId Int
  itemId    Int
  qty       Decimal @db.Decimal(18, 3)

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([enquiryId])
}

model Feasibility {
  id        Int          @id @default(autoincrement())
  enquiryId Int          @unique
  status    SimpleStatus
  remarks   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
}

model Quotation {
  id                        Int                     @id @default(autoincrement())
  enquiryId                 Int                     @unique
  quotationNo               String?                 @unique
  /// Immutable snapshot of originating enquiry flow type (used for future SO branching).
  flowTypeSnapshot          EnquiryFlowType         @default(REGULAR)
  workflowStatus            QuotationWorkflowStatus @default(DRAFT)
  status                    SimpleStatus            @default(PENDING)
  subtotal                  Decimal                 @default(0) @db.Decimal(18, 2)
  gstTotal                  Decimal                 @default(0) @db.Decimal(18, 2)
  totalAmount               Decimal                 @default(0) @db.Decimal(18, 2)
  terms                     String?
  /// Admin-only: when approval is cancelled, store reason + audit timestamp.
  approvalCancelReason      String?
  approvalCancelledAt       DateTime?
  approvalCancelledByUserId Int?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  enquiry             Enquiry         @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  lines               QuotationLine[]
  salesOrder           SalesOrder?
  materialRequirements MaterialRequirement[]
  approvalCancelledBy  User?           @relation("QuotationApprovalCancelledBy", fields: [approvalCancelledByUserId], references: [id], onDelete: SetNull)

  @@index([flowTypeSnapshot])
  @@index([workflowStatus])
  @@index([approvalCancelledByUserId])
}

model QuotationLine {
  id          Int     @id @default(autoincrement())
  quotationId Int
  itemId      Int
  qty         Decimal @db.Decimal(18, 3)
  rate        Decimal @db.Decimal(18, 2)
  discountPct Decimal @default(0) @db.Decimal(18, 2)
  gstPct      Decimal @default(18) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  /// For NO_QTY quotations: snapshot the applicable approved contract line.
  rateContractLineIdSnapshot Int?
  /// For NO_QTY quotations: contract effectiveFrom (UTC date) used for the snapshot.
  rateEffectiveFromSnapshot  DateTime?
  /// When true, rate is stored as 0 and the line is treated as intentionally free (not a pricing error).
  isFree      Boolean @default(false)

  quotation            Quotation                @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  item                 Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  salesOrderLines SalesOrderLine[]

  @@index([quotationId])
  @@index([rateContractLineIdSnapshot])
}

enum RateContractLineStatus {
  APPROVED
  SUPERSEDED
  INACTIVE
}

model RateContractLine {
  id                    Int                    @id @default(autoincrement())
  customerId            Int
  itemId                Int
  rate                  Decimal                @db.Decimal(18, 4)
  gstRate               Decimal                @db.Decimal(5, 2)
  effectiveFrom         DateTime
  status                RateContractLineStatus @default(APPROVED)
  revisedFromId         Int?
  createdByUserId       Int?
  deactivatedAt         DateTime?
  deactivatedByUserId   Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  customer      Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  item          Item                @relation(fields: [itemId], references: [id], onDelete: Restrict)
  revisedFrom   RateContractLine?   @relation("RateContractLineRevisions", fields: [revisedFromId], references: [id], onDelete: SetNull)
  revisions     RateContractLine[]  @relation("RateContractLineRevisions")
  createdBy     User?               @relation("RateContractLineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deactivatedBy User?               @relation("RateContractLineDeactivatedBy", fields: [deactivatedByUserId], references: [id], onDelete: SetNull)

  @@index([customerId, itemId, effectiveFrom])
  @@index([status])
  @@index([revisedFromId])
  @@index([createdByUserId])
  @@index([deactivatedByUserId])
}

model CustomerPO {
  id           Int          @id @default(autoincrement())
  customerId   Int
  supplierId   Int?
  /// Customer-provided purchase order number (primary identifier in UI).
  poNumber     String       @db.VarChar(64)
  /// Customer PO date.
  poDate       DateTime
  /// Customer-requested delivery/required date (optional).
  requiredDate DateTime?
  status       SimpleStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplier   Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines      CustomerPOLine[]
  salesOrder SalesOrder?

  @@index([customerId])
  @@index([status])
  @@index([poNumber])
}

model CustomerPOLine {
  id          Int     @id @default(autoincrement())
  poId        Int
  itemId      Int
  qty         Decimal @db.Decimal(18, 3)
  rate        Decimal @db.Decimal(18, 2)
  discountPct Decimal @default(0) @db.Decimal(18, 2)
  gstPct      Decimal @default(18) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  po   CustomerPO @relation(fields: [poId], references: [id], onDelete: Cascade)
  item Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([poId])
}

/// Singleton app configuration (id = 1)
model AppSetting {
  id                                Int     @id @default(1)
  /// Max allowed rejection buffer % on NORMAL sales order lines (0–100). Admin-configurable.
  maxRegularSoBufferPercent         Decimal @default(10) @db.Decimal(18, 2)
  strictInventoryControl            Boolean @default(false)
  /// ADMIN_ONLY | ADMIN_AND_STORE — who may reverse stock adjustments
  stockAdjustmentReverseRoles       String  @default("ADMIN_ONLY")
  /// SAME_DAY | HOURS | DAYS | NO_LIMIT
  stockAdjustmentReverseWindowType  String  @default("HOURS")
  stockAdjustmentReverseWindowValue Int     @default(24)
  /// ADMIN_ONLY | ADMIN_AND_STORE — who may create stock adjustments
  stockAdjustmentCreateRoles        String  @default("ADMIN_AND_STORE")
  /// Registered company state (free text); for future CGST+SGST vs IGST. No calculation yet.
  companyState                      String? @db.VarChar(128)
  /// Structured company state reference (GST code mapping). Nullable for backward compatibility.
  companyStateId                    Int?
  /// Company GSTIN (nullable; no strict validation in demo mode).
  companyGstin                      String? @db.VarChar(15)

  /// ===== Company Profile (document branding only) =====
  /// All fields below are purely presentational — they drive Quotation /
  /// Sales Bill / Purchase Bill / future document chrome. They DO NOT
  /// participate in GST math, Tally export, numbering, or any calculation.
  companyName                       String? @db.VarChar(160)
  companyAddressLine1               String? @db.VarChar(160)
  companyAddressLine2               String? @db.VarChar(160)
  companyCity                       String? @db.VarChar(96)
  companyPincode                    String? @db.VarChar(12)
  companyPan                        String? @db.VarChar(10)
  companyMobile                     String? @db.VarChar(32)
  companyPhone                      String? @db.VarChar(32)
  companyEmail                      String? @db.VarChar(160)
  companyWebsite                    String? @db.VarChar(160)
  /// Path (relative to BRANDING_STORAGE_DIR) of the uploaded company logo.
  companyLogoPath                   String? @db.VarChar(255)
  companyLogoMime                   String? @db.VarChar(64)
  /// Free-text authorised signatory name printed under documents.
  companySignatoryName              String? @db.VarChar(160)
  companySignaturePath              String? @db.VarChar(255)
  companySignatureMime              String? @db.VarChar(64)

  companyStateRef State? @relation(fields: [companyStateId], references: [id], onDelete: SetNull)
}

model State {
  id        Int      @id @default(autoincrement())
  stateName String   @db.VarChar(128)
  /// GST state code (2-digit string): e.g. "27" Maharashtra, "07" Delhi.
  stateCode String   @db.VarChar(2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  suppliers   Supplier[]
  supplierLocations SupplierLocation[]
  customers   Customer[]
  customerDeliveryAddresses CustomerDeliveryAddress[]
  appSettings AppSetting[]

  @@unique([stateName])
  @@unique([stateCode])
  @@index([isActive])
}

model SalesOrder {
  id                   Int                      @id @default(autoincrement())
  /// Display document number (e.g. SO-24-0001). Auto-generated on create.
  docNo                String?                  @unique @db.VarChar(32)
  poId                 Int?                     @unique
  customerId           Int?
  /// Operational ship-to reference (nullable for legacy SOs; does not affect NO_QTY cycle logic).
  shipToAddressId      Int?
  quotationId          Int?                     @unique
  customerPoReference  String?
  remarks              String?
  orderType            SalesOrderType           @default(NORMAL)
  /// For replacement orders created from an approved customer return (phase 1: one SO per return).
  customerReturnId     Int?                     @unique
  originalSalesOrderId Int?
  originalDispatchId   Int?
  internalStatus       SalesOrderInternalStatus @default(DRAFT)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  /// Commercial snapshots (frozen after approval/open per sales flow; nullable for backward compatibility).
  billToNameSnapshot        String? @db.VarChar(256)
  billToAddressSnapshot     String? @db.Text
  billToGstinSnapshot       String? @db.VarChar(15)
  billToStateNameSnapshot   String? @db.VarChar(128)
  billToStateCodeSnapshot   String? @db.VarChar(2)

  shipToLabelSnapshot       String? @db.VarChar(128)
  shipToAddressSnapshot     String? @db.Text
  shipToGstinSnapshot       String? @db.VarChar(15)
  shipToStateNameSnapshot   String? @db.VarChar(128)
  shipToStateCodeSnapshot   String? @db.VarChar(2)

  posStateNameSnapshot      String? @db.VarChar(128)
  posStateCodeSnapshot      String? @db.VarChar(2)
  /// POS source at freeze time: SHIP_TO | BILL_TO | MANUAL (nullable until frozen).
  posSourceSnapshot         String? @db.VarChar(32)

  /// NO_QTY: current active workflow cycle (null for legacy rows created before cycles).
  currentCycleId Int? @unique

  customer                 Customer?                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shipToAddress            CustomerDeliveryAddress? @relation(fields: [shipToAddressId], references: [id], onDelete: SetNull)
  quotation                Quotation?               @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  po                       CustomerPO?              @relation(fields: [poId], references: [id], onDelete: Cascade)
  replacementForReturn     CustomerReturn?          @relation("ReplacementForReturn", fields: [customerReturnId], references: [id], onDelete: SetNull)
  lines                    SalesOrderLine[]
  dispatch                 Dispatch[]
  workOrders               WorkOrder[]
  requirementSheets        RequirementSheet[]
  materialRequirements     MaterialRequirement[]
  materialAllocations      MaterialAllocation[]
  stockAdjustmentQcEntries StockAdjustmentQcEntry[]
  customerReturns          CustomerReturn[]
  regularSoPlanningSnapshot RegularSoPlanningSnapshot?
  regularSoPlanningSnapshotLines RegularSoPlanningSnapshotLine[]

  cycles       SalesOrderCycle[]
  currentCycle SalesOrderCycle?  @relation("SalesOrderCurrentCycle", fields: [currentCycleId], references: [id], onDelete: SetNull)
  noQtyCloseSnapshots NoQtySoCloseSnapshot[]
  noQtyClosedShortageLines NoQtySoClosedShortageLine[]

  @@index([customerId])
  @@index([shipToAddressId])
  @@index([orderType])
  @@index([customerReturnId])
  @@index([internalStatus])
  @@index([currentCycleId])
}

model RegularSoPlanningSnapshot {
  id              Int      @id @default(autoincrement())
  salesOrderId    Int      @unique
  bufferPercent   Decimal  @default(0) @db.Decimal(18, 2)
  createdByUserId Int?
  updatedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("RegularSoPlanningSnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("RegularSoPlanningSnapshotUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lines      RegularSoPlanningSnapshotLine[]

  @@index([salesOrderId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model RegularSoPlanningSnapshotLine {
  id                      Int      @id @default(autoincrement())
  snapshotId              Int
  salesOrderId            Int
  salesOrderLineId        Int      @unique
  customerCommittedQty    Decimal  @db.Decimal(18, 3)
  productionBufferPercent Decimal  @default(0) @db.Decimal(18, 2)
  productionBufferQty     Decimal  @default(0) @db.Decimal(18, 3)
  plannedProductionQty    Decimal  @db.Decimal(18, 3)
  fgStockAdjustmentQty    Decimal  @default(0) @db.Decimal(18, 3)
  rmPlanningQty           Decimal  @db.Decimal(18, 3)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  snapshot       RegularSoPlanningSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  salesOrder     SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  salesOrderLine SalesOrderLine            @relation(fields: [salesOrderLineId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([salesOrderId])
}

model NoQtySoCloseSnapshot {
  id               Int      @id @default(autoincrement())
  salesOrderId     Int
  closeVersion     Int
  closedAt         DateTime @default(now())
  closedByUserId   Int?
  reopenMode       String?  @db.VarChar(32)
  reopenedAt       DateTime?
  reopenedByUserId Int?
  status           String   @default("ACTIVE") @db.VarChar(32)
  reason           String?  @db.Text

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  closedBy   User?      @relation("NoQtySoCloseSnapshotClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  reopenedBy User?      @relation("NoQtySoCloseSnapshotReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)
  lines      NoQtySoClosedShortageLine[]

  @@unique([salesOrderId, closeVersion])
  @@index([salesOrderId])
}

model NoQtySoClosedShortageLine {
  id               Int     @id @default(autoincrement())
  snapshotId       Int
  salesOrderId     Int
  itemId           Int
  cycleIdAtClose   Int?
  cycleNoAtClose   Int?
  closedShortageQty Decimal @default(0) @db.Decimal(18, 3)

  snapshot  NoQtySoCloseSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder          @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item      Item                 @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([snapshotId])
  @@index([salesOrderId])
  @@index([itemId])
}

model SalesOrderLine {
  id              Int     @id @default(autoincrement())
  soId            Int
  itemId          Int
  /// Customer / legal dispatch & billing cap (NORMAL). Backfilled from legacy qty.
  customerPoQty   Decimal @default(0) @db.Decimal(18, 3)
  /// Rejection planning buffer % (NORMAL only; 0 = off). Planned qty = customerPoQty + ceil(customerPoQty * buffer / 100).
  bufferPercent   Decimal @default(0) @db.Decimal(18, 2)
  /// Planned production qty (WO / RM check). For NORMAL: derived from customerPoQty + bufferPercent.
  qty             Decimal @db.Decimal(18, 3)
  /// Manual NO_QTY SO: capture rate for downstream billing; quotation-based flow uses quotation line rate.
  rate            Decimal @default(0) @db.Decimal(18, 4)
  /// NO_QTY: GST rate snapshot for downstream billing (nullable for legacy).
  gstRate         Decimal? @db.Decimal(5, 2)
  /// NO_QTY: rate effective-from snapshot (nullable for legacy).
  rateEffectiveFrom DateTime?
  /// When SO is created from a quotation, links to that quotation line (source of truth for pricing/free intent).
  quotationLineId Int?
  /// Commercial snapshot from QuotationLine.isFree at SO creation (read-only downstream). Not used for RM/WO/QC/dispatch math.
  isFree          Boolean @default(false)

  so            SalesOrder     @relation(fields: [soId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quotationLine QuotationLine? @relation(fields: [quotationLineId], references: [id], onDelete: SetNull)
  planningSnapshotLine RegularSoPlanningSnapshotLine?

  @@index([soId])
  @@index([quotationLineId])
}

enum DispatchWorkflowStatus {
  /// Draft: no stock/SO finalization until locked.
  UNLOCKED
  /// Confirmed: stock out posted; not editable; reversible only via reversal rows.
  LOCKED
}

enum RequirementSheetStatus {
  DRAFT
  LOCKED
}

enum RequirementSheetColorZone {
  GREEN
  YELLOW
  RED
  EXCESS
}

/// One row per dispatch event; partial dispatch per sales order (aggregated qty for SO).
/// Reversals: dispatchedQty negative, reversalOfId points at original forward dispatch row.
model Dispatch {
  id             Int                    @id @default(autoincrement())
  /// Display document number (e.g. D-24-0001). Auto-generated on create.
  docNo          String?                @unique @db.VarChar(32)
  soId           Int
  itemId         Int
  /// NO_QTY: workflow cycle isolation (null for legacy / non-NO_QTY flows).
  cycleId        Int?
  dispatchedQty  Decimal                @db.Decimal(18, 3)
  reversalOfId   Int?
  reversalReason String?
  /// Forward rows: UNLOCKED until confirmed; reversal rows always LOCKED.
  workflowStatus DispatchWorkflowStatus @default(LOCKED)
  date           DateTime               @default(now())

  salesOrder      SalesOrder       @relation(fields: [soId], references: [id], onDelete: Cascade)
  cycle           SalesOrderCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  item            Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  reversalOf      Dispatch?        @relation("DispatchReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversals       Dispatch[]       @relation("DispatchReversal")
  customerReturns CustomerReturn[]
  salesBills      SalesBill[]

  @@index([soId])
  @@index([cycleId])
  @@index([date])
  @@index([reversalOfId])
}

/// Requirement planning sheet for NO_QTY sales orders (versioned per period).
model RequirementSheet {
  id             Int                    @id @default(autoincrement())
  /// Display document number (e.g. RS-24-0001). Auto-generated on create.
  docNo          String?                @unique @db.VarChar(32)
  salesOrderId   Int
  /// NO_QTY: workflow cycle isolation (null for legacy rows created before cycles).
  cycleId        Int?
  periodKey      String                 @db.VarChar(16) // e.g. "2026-04"
  version        Int                    @default(1)
  status         RequirementSheetStatus @default(DRAFT)
  remarks        String?
  recalculatedAt DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  salesOrder SalesOrder             @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  cycle      SalesOrderCycle?       @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  lines      RequirementSheetLine[]
  workOrders WorkOrder[]

  @@unique([salesOrderId, cycleId, periodKey, version])
  @@index([salesOrderId])
  @@index([cycleId])
  @@index([periodKey])
  @@index([status])
}

model RequirementSheetLine {
  id                        Int                        @id @default(autoincrement())
  sheetId                   Int
  itemId                    Int
  requirementQty            Decimal                    @db.Decimal(18, 3)
  /// NO_QTY: operator carry-forward shortfall from latest previous cycle (planned qty - approved produced qty). Snapshot on lock.
  shortfallQtySnapshot      Decimal?                   @db.Decimal(18, 3)
  availableStockQtySnapshot Decimal?                   @db.Decimal(18, 3)
  gapPercentSnapshot        Decimal?                   @db.Decimal(18, 2)
  suggestedWoQtySnapshot    Decimal?                   @db.Decimal(18, 3)
  colorZoneSnapshot         RequirementSheetColorZone?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  sheet RequirementSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  item  Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([sheetId, itemId])
  @@index([sheetId])
  @@index([itemId])
}

enum MaterialRequirementStatus {
  /// Store requisition draft; not visible to Purchase.
  DRAFT
  /// Store requisition awaiting Store approval; not visible to Purchase.
  PENDING_APPROVAL
  /// Store-approved requisition; visible for Store-to-Purchase handoff.
  APPROVED
  /// Requisition sent to Purchase.
  SENT_TO_PURCHASE
  /// Purchase is executing supplier PO / follow-up.
  PROCUREMENT_IN_PROGRESS
  PARTIALLY_PROCURED
  FULLY_PROCURED
  CLOSED
  CANCELLED
}

enum MaterialPlanningSourceType {
  QUOTATION
  SALES_ORDER
  /// REGULAR Prepare Work Order — RM shortage from planned FG qty (Store → Purchase).
  WORK_ORDER_PLANNING
  /// Store-level RM minimum stock replenishment; not linked to SO/RS/WO/production.
  STOCK_REPLENISHMENT
  /// Planning-driven RM demand released from a locked Monthly Production Plan.
  MONTHLY_PLAN
}

/// Monthly Planning Workspace plan-document lifecycle.
/// LOCKED is legacy (revision model); retained for backward compatibility until migration completes.
enum MonthlyProductionPlanStatus {
  DRAFT
  AWAITING_PURCHASE_REVIEW
  APPROVED
  LOCKED
}

enum MonthlyProductionPlanKind {
  INITIAL
  ADDITIONAL
}

/// Provenance of a Monthly Production Plan FG line's suggested quantity.
/// CUSTOMER_SCHEDULE is reserved for a later phase (not populated in Phase 1).
enum MonthlyPlanLineSource {
  CUSTOMER_SCHEDULE
  SALES_ORDER
  REQUIREMENT_SHEET
  MANUAL
}

/// Monthly Production Plan — plan-document model (multiple per period). Store-owned.
model MonthlyProductionPlan {
  id               Int                         @id @default(autoincrement())
  docNo            String?                     @unique @db.VarChar(32)
  periodKey        String                      @db.VarChar(16) // e.g. "2026-06"
  /// Per-period sequence: Plan 1, Plan 2, …
  planSequenceNo   Int                         @default(1)
  planKind         MonthlyProductionPlanKind   @default(INITIAL)
  status           MonthlyProductionPlanStatus @default(DRAFT)
  /// @deprecated Revision model — retained for legacy plans; do not use for new plan documents.
  currentRevision  Int                         @default(0)
  remarks          String?                     @db.Text

  lockedAt         DateTime?
  lockedByUserId   Int?
  /// @deprecated Reopen model — scheduled for removal.
  reopenedAt       DateTime?
  /// @deprecated Reopen model — scheduled for removal.
  reopenedByUserId Int?
  purchaseReviewedAt       DateTime?
  purchaseReviewedByUserId Int?
  approvedAt       DateTime?
  approvedByUserId Int?
  purchaseRejectReason String?                 @db.Text
  /// "Released to procurement" is a flag, not a status.
  releasedAt       DateTime?
  releasedByUserId Int?
  /// @deprecated Revision model — scheduled for removal.
  releasedRevision Int?

  createdByUserId  Int?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  lines                MonthlyProductionPlanLine[]
  revisionLines        MonthlyProductionPlanRevisionLine[]
  rmPlans              RmPlan[]
  materialRequirements MaterialRequirement[]       @relation("MaterialRequirementMonthlyPlan")
  createdBy            User?                       @relation("MppCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lockedBy             User?                       @relation("MppLockedBy", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  reopenedBy           User?                       @relation("MppReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)
  releasedBy           User?                       @relation("MppReleasedBy", fields: [releasedByUserId], references: [id], onDelete: SetNull)
  purchaseReviewedBy   User?                       @relation("MppPurchaseReviewedBy", fields: [purchaseReviewedByUserId], references: [id], onDelete: SetNull)
  approvedBy           User?                       @relation("MppApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([periodKey, planSequenceNo])
  @@index([status])
  @@index([periodKey])
  @@index([releasedAt])
  @@index([periodKey, status])
}

/// Monthly Production Plan FG demand line. Aggregate per FG per plan (no SO/RS scalar FK by design).
model MonthlyProductionPlanLine {
  id             Int                   @id @default(autoincrement())
  planId         Int
  fgItemId       Int
  suggestedFgQty Decimal               @default(0) @db.Decimal(18, 3)
  plannedFgQty   Decimal               @default(0) @db.Decimal(18, 3)
  /// True when Store manually edited planned qty; auto-fill must not overwrite.
  plannedQtyOverridden Boolean          @default(false)
  source         MonthlyPlanLineSource @default(MANUAL)
  remarks        String?               @db.Text
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  plan   MonthlyProductionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  fgItem Item                  @relation("MppLineFgItem", fields: [fgItemId], references: [id], onDelete: Restrict)

  @@unique([planId, fgItemId])
  @@index([planId])
  @@index([fgItemId])
}

/// Immutable FG Production Plan snapshot for one lock revision (audit / revision history).
model MonthlyProductionPlanRevisionLine {
  id                   Int                   @id @default(autoincrement())
  planId               Int
  revision             Int
  fgItemId             Int
  suggestedFgQty       Decimal               @default(0) @db.Decimal(18, 3)
  plannedFgQty         Decimal               @default(0) @db.Decimal(18, 3)
  plannedQtyOverridden Boolean               @default(false)
  source               MonthlyPlanLineSource @default(MANUAL)
  remarks              String?               @db.Text
  unitSnapshot         String?               @db.VarChar(64)
  itemNameSnapshot     String?               @db.VarChar(255)
  createdAt            DateTime              @default(now())

  plan   MonthlyProductionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  fgItem Item                  @relation("MppRevisionLineFgItem", fields: [fgItemId], references: [id], onDelete: Restrict)

  @@unique([planId, revision, fgItemId])
  @@index([planId, revision])
  @@index([fgItemId])
}

/// Immutable RM Planning snapshot for one lock of a Monthly Production Plan (one per revision).
model RmPlan {
  id                   Int      @id @default(autoincrement())
  planId               Int
  revision             Int
  totalFgPlannedQty    Decimal  @default(0) @db.Decimal(18, 3)
  fgPlanHashSnapshot   String?  @db.VarChar(64)
  recalculatedAt       DateTime @default(now())
  recalculatedByUserId Int?

  plan          MonthlyProductionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  lines         RmPlanLine[]
  recalculatedBy User?                @relation("RmPlanRecalcBy", fields: [recalculatedByUserId], references: [id], onDelete: SetNull)

  @@unique([planId, revision])
  @@index([planId])
}

/// Immutable RM demand line within an RmPlan snapshot.
model RmPlanLine {
  id                 Int      @id @default(autoincrement())
  rmPlanId           Int
  rmItemId           Int
  grossDemandQty     Decimal  @default(0) @db.Decimal(18, 3)
  freeStockSnapshot  Decimal  @default(0) @db.Decimal(18, 3)
  reservedSnapshot   Decimal  @default(0) @db.Decimal(18, 3)
  incomingPoSnapshot Decimal  @default(0) @db.Decimal(18, 3)
  minStockTopUpQty   Decimal  @default(0) @db.Decimal(18, 3)
  netRequirementQty  Decimal  @default(0) @db.Decimal(18, 3)
  unitSnapshot       String?  @db.VarChar(64)
  leadTimeRiskFlag   Boolean  @default(false)
  belowMinStockFlag  Boolean  @default(false)
  warningsJson       Json?

  rmPlan RmPlan @relation(fields: [rmPlanId], references: [id], onDelete: Cascade)
  rmItem Item   @relation("RmPlanLineRmItem", fields: [rmItemId], references: [id], onDelete: Restrict)

  @@unique([rmPlanId, rmItemId])
  @@index([rmPlanId])
  @@index([rmItemId])
}

/// Store material planning output — RM Requisition (not a PO).
model MaterialRequirement {
  id              Int                        @id @default(autoincrement())
  docNo           String?                    @unique @db.VarChar(32)
  status          MaterialRequirementStatus  @default(DRAFT)
  sourceType      MaterialPlanningSourceType
  quotationId     Int?
  salesOrderId    Int?
  /// REGULAR WO prepare: optional link when a work order already exists for this SO.
  workOrderId     Int?
  fgItemId        Int?
  plannedProductionQty Decimal?              @db.Decimal(18, 3)
  /// Monthly Planning (Phase 1): plan that released this MR (variance anchor). Null for all legacy/non-plan MRs.
  monthlyProductionPlanId Int?
  /// Monthly Planning (Phase 1): plan revision that produced this MR (traceability; optional).
  sourceRevision  Int?
  createdByUserId Int?
  reversedAt      DateTime?
  reversedByUserId Int?
  reversalReason  String?                    @db.Text
  requiredDate    DateTime?                  @db.Date
  raisedByUserId  Int?
  approvedByUserId Int?
  approvedAt      DateTime?
  sentToPurchaseAt DateTime?
  closedAt        DateTime?
  requisitionRemarks String?                 @db.Text
  approvalRemarks String?                    @db.Text
  remarks         String?                    @db.Text
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  quotation  Quotation?  @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  workOrder  WorkOrder?  @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  fgItem     Item?       @relation("MaterialRequirementFgItem", fields: [fgItemId], references: [id], onDelete: SetNull)
  createdBy  User?       @relation("MaterialRequirementCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reversedBy User?       @relation("MaterialRequirementReversedBy", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  raisedBy   User?       @relation("MaterialRequirementRaisedBy", fields: [raisedByUserId], references: [id], onDelete: SetNull)
  approvedBy User?       @relation("MaterialRequirementApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  monthlyProductionPlan MonthlyProductionPlan? @relation("MaterialRequirementMonthlyPlan", fields: [monthlyProductionPlanId], references: [id], onDelete: SetNull)
  lines      MaterialRequirementLine[]

  @@index([quotationId])
  @@index([salesOrderId])
  @@index([workOrderId])
  @@index([fgItemId])
  @@index([status])
  @@index([createdByUserId])
  @@index([reversedByUserId])
  @@index([raisedByUserId])
  @@index([approvedByUserId])
  @@index([sentToPurchaseAt])
  @@index([monthlyProductionPlanId])
}

model MaterialRequirementLine {
  id                    Int     @id @default(autoincrement())
  materialRequirementId Int
  rmItemId              Int
  requiredQty           Decimal @db.Decimal(18, 3)
  shortageQty           Decimal @db.Decimal(18, 3)
  availableQtySnapshot  Decimal @default(0) @db.Decimal(18, 3)
  unitSnapshot          String? @db.VarChar(64)
  /// Qty already covered by linked RM PO lines (planning traceability; not stock reservation).
  procuredQty           Decimal @default(0) @db.Decimal(18, 3)

  materialRequirement MaterialRequirement       @relation(fields: [materialRequirementId], references: [id], onDelete: Cascade)
  rmItem              Item                      @relation(fields: [rmItemId], references: [id], onDelete: Restrict)
  procurementLinks         RmPoLineProcurementLink[]
  purchaseRequestSourceLinks PurchaseRequestLineSourceLink[]

  @@unique([materialRequirementId, rmItemId])
  @@index([materialRequirementId])
  @@index([rmItemId])
}

/// Traceability: RM PO line fulfillment of a purchase request line (Purchase dept stage).
model RmPoLineProcurementLink {
  id                        Int     @id @default(autoincrement())
  rmPoLineId                Int
  purchaseRequestLineId     Int?
  /// Legacy direct MR link (pre–purchase-request flow); prefer purchaseRequestLineId.
  materialRequirementLineId Int?
  allocatedQty              Decimal @db.Decimal(18, 3)

  rmPoLine                RmPurchaseOrderLine     @relation(fields: [rmPoLineId], references: [id], onDelete: Cascade)
  purchaseRequestLine     PurchaseRequestLine?    @relation(fields: [purchaseRequestLineId], references: [id], onDelete: Restrict)
  materialRequirementLine MaterialRequirementLine? @relation(fields: [materialRequirementLineId], references: [id], onDelete: Restrict)

  @@index([rmPoLineId])
  @@index([purchaseRequestLineId])
  @@index([materialRequirementLineId])
}

/// Consolidated RM requirement sent from Store to Purchase (not an RM PO).
model PurchaseRequest {
  id              Int                   @id @default(autoincrement())
  docNo           String?               @unique @db.VarChar(32)
  status          PurchaseRequestStatus @default(PENDING_PURCHASE)
  remarks         String?               @db.Text
  createdByUserId Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  createdBy User?               @relation("PurchaseRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines     PurchaseRequestLine[]

  @@index([status])
  @@index([createdByUserId])
}

model PurchaseRequestLine {
  id                   Int     @id @default(autoincrement())
  purchaseRequestId    Int
  rmItemId             Int
  requiredQty          Decimal @db.Decimal(18, 3)
  availableQtySnapshot Decimal @default(0) @db.Decimal(18, 3)
  netRequiredQty       Decimal @db.Decimal(18, 3)
  orderedQty           Decimal @default(0) @db.Decimal(18, 3)
  unitSnapshot         String? @db.VarChar(64)

  purchaseRequest PurchaseRequest                 @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  rmItem          Item                            @relation(fields: [rmItemId], references: [id], onDelete: Restrict)
  sourceLinks     PurchaseRequestLineSourceLink[]
  poLinks         RmPoLineProcurementLink[]

  @@unique([purchaseRequestId, rmItemId])
  @@index([purchaseRequestId])
  @@index([rmItemId])
}

/// Traceability: purchase request line back to originating material requirement lines.
model PurchaseRequestLineSourceLink {
  id                        Int     @id @default(autoincrement())
  purchaseRequestLineId     Int
  materialRequirementLineId Int
  allocatedQty              Decimal @db.Decimal(18, 3)

  purchaseRequestLine     PurchaseRequestLine     @relation(fields: [purchaseRequestLineId], references: [id], onDelete: Cascade)
  materialRequirementLine MaterialRequirementLine @relation(fields: [materialRequirementLineId], references: [id], onDelete: Restrict)

  @@index([purchaseRequestLineId])
  @@index([materialRequirementLineId])
}

/// Production material request (PMR) — request/control layer before MIN stock transfer.
model ProductionMaterialRequest {
  id                Int                             @id @default(autoincrement())
  docNo             String?                         @unique @db.VarChar(32)
  workOrderId       Int
  status            ProductionMaterialRequestStatus @default(DRAFT)
  remarks           String?                         @db.Text
  requestedAt       DateTime?
  requestedByUserId Int?
  createdByUserId   Int?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt

  workOrder           WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  requestedBy         User?               @relation("PmrRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  createdBy           User?               @relation("PmrCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines               ProductionMaterialRequestLine[]
  materialIssueNotes  MaterialIssueNote[]
  materialReturnNotes MaterialReturnNote[]
  materialWastageNotes MaterialWastageNote[]
  materialAllocations MaterialAllocation[]

  @@index([workOrderId])
  @@index([status])
  @@index([requestedByUserId])
  @@index([createdByUserId])
}

model ProductionMaterialRequestLine {
  id                          Int     @id @default(autoincrement())
  productionMaterialRequestId Int
  itemId                      Int
  requiredQty                 Decimal @db.Decimal(18, 3)
  issuedQty                   Decimal @default(0) @db.Decimal(18, 3)
  returnedQty                 Decimal @default(0) @db.Decimal(18, 3)
  unitSnapshot                String? @db.VarChar(64)

  productionMaterialRequest ProductionMaterialRequest @relation(fields: [productionMaterialRequestId], references: [id], onDelete: Cascade)
  item                      Item                      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([productionMaterialRequestId, itemId], map: "PmrLine_pmrId_itemId_key")
  @@index([productionMaterialRequestId])
  @@index([itemId])
}

/// Store material issue to production location (MIN). Stock movement only — not production consumption.
model MaterialAllocation {
  id                          Int                        @id @default(autoincrement())
  allocationNo                String?                    @unique @db.VarChar(32)
  rmItemId                    Int
  salesOrderId                Int?
  workOrderId                 Int?
  workOrderLineId             Int?
  productionMaterialRequestId Int?
  sourceLocationId            Int?
  qtyAllocated                Decimal                    @db.Decimal(18, 3)
  qtyIssued                   Decimal                    @default(0) @db.Decimal(18, 3)
  status                      MaterialAllocationStatus
  priority                    MaterialAllocationPriority @default(NORMAL)
  allocationType              MaterialAllocationType
  remarks                     String?                    @db.Text
  createdByUserId             Int?
  releasedByUserId            Int?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  rmItem                    Item                       @relation("MaterialAllocationRmItem", fields: [rmItemId], references: [id], onDelete: Restrict)
  salesOrder                SalesOrder?                @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  workOrder                 WorkOrder?                 @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  workOrderLine             WorkOrderLine?             @relation(fields: [workOrderLineId], references: [id], onDelete: SetNull)
  productionMaterialRequest ProductionMaterialRequest? @relation(fields: [productionMaterialRequestId], references: [id], onDelete: SetNull)
  sourceLocation            Location?                  @relation(fields: [sourceLocationId], references: [id], onDelete: SetNull)
  createdBy                 User?                      @relation("MaterialAllocationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  releasedBy                User?                      @relation("MaterialAllocationReleasedBy", fields: [releasedByUserId], references: [id], onDelete: SetNull)

  @@index([rmItemId, status])
  @@index([salesOrderId])
  @@index([workOrderId])
  @@index([workOrderLineId])
  @@index([productionMaterialRequestId])
  @@index([sourceLocationId])
  @@index([status])
  @@index([createdByUserId])
  @@index([releasedByUserId])
}

model MaterialIssueNote {
  id                          Int      @id @default(autoincrement())
  docNo                       String?  @unique @db.VarChar(32)
  fromLocationId              Int
  toLocationId                Int
  workOrderId                 Int?
  productionMaterialRequestId Int?
  remarks                     String?  @db.Text
  createdByUserId             Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  fromLocation              Location                   @relation("MaterialIssueFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation                Location                   @relation("MaterialIssueToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  workOrder                 WorkOrder?                 @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  productionMaterialRequest ProductionMaterialRequest? @relation(fields: [productionMaterialRequestId], references: [id], onDelete: SetNull)
  createdBy                 User?                      @relation("MaterialIssueCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                     MaterialIssueLine[]

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([workOrderId])
  @@index([productionMaterialRequestId])
  @@index([createdByUserId])
}

model MaterialIssueLine {
  id                  Int     @id @default(autoincrement())
  materialIssueNoteId Int
  itemId              Int
  issueQty            Decimal @db.Decimal(18, 3)
  unitSnapshot        String? @db.VarChar(64)

  materialIssueNote MaterialIssueNote @relation(fields: [materialIssueNoteId], references: [id], onDelete: Cascade)
  item              Item              @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([materialIssueNoteId])
  @@index([itemId])
}

/// Production → Store RM return (MRN). Stock movement only — paired LOCATION_TRANSFER (inverse of MIN).
model MaterialReturnNote {
  id                          Int      @id @default(autoincrement())
  docNo                       String?  @unique @db.VarChar(32)
  fromLocationId              Int
  toLocationId                Int
  workOrderId                 Int?
  productionMaterialRequestId Int?
  remarks                     String?  @db.Text
  createdByUserId             Int?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  fromLocation              Location                   @relation("MaterialReturnFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation                Location                   @relation("MaterialReturnToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  workOrder                 WorkOrder?                 @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  productionMaterialRequest ProductionMaterialRequest? @relation(fields: [productionMaterialRequestId], references: [id], onDelete: SetNull)
  createdBy                 User?                      @relation("MaterialReturnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                     MaterialReturnLine[]

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([workOrderId])
  @@index([productionMaterialRequestId])
  @@index([createdByUserId])
}

model MaterialReturnLine {
  id                   Int      @id @default(autoincrement())
  materialReturnNoteId Int
  itemId               Int
  returnQty            Decimal  @db.Decimal(18, 3)
  remarks              String?  @db.Text
  unitSnapshot         String?  @db.VarChar(64)

  materialReturnNote MaterialReturnNote @relation(fields: [materialReturnNoteId], references: [id], onDelete: Cascade)
  item               Item               @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([materialReturnNoteId])
  @@index([itemId])
}

/// Production-location RM wastage declaration (MWN). Final loss — no return to store.
model MaterialWastageNote {
  id                          Int             @id @default(autoincrement())
  docNo                       String?         @unique @db.VarChar(32)
  workOrderId                 Int
  productionMaterialRequestId Int?
  fromLocationId              Int
  itemId                      Int
  qty                         Decimal         @db.Decimal(18, 3)
  reason                      RmWastageReason
  remarks                     String?         @db.Text
  createdByUserId             Int?
  createdAt                   DateTime        @default(now())

  fromLocation              Location                   @relation("MaterialWastageFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  workOrder                 WorkOrder                  @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  productionMaterialRequest ProductionMaterialRequest? @relation(fields: [productionMaterialRequestId], references: [id], onDelete: SetNull)
  item                      Item                       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy                 User?                      @relation("MaterialWastageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([productionMaterialRequestId])
  @@index([fromLocationId])
  @@index([itemId])
  @@index([createdByUserId])
  @@index([createdAt])
  @@index([reason])
}

/// Customer sales invoice against one confirmed dispatch row (phase 1: 1 dispatch = 1 sales bill).
model SalesBill {
  id         Int             @id @default(autoincrement())
  /// Display document number (e.g. SB-24-0001). Auto-generated on create.
  docNo      String?         @unique @db.VarChar(32)
  billNo     String?         @db.VarChar(128)
  billDate   DateTime        @db.Date
  customerId Int
  dispatchId Int
  /// NO_QTY: workflow cycle isolation (copied from Dispatch.cycleId at creation; null for legacy / non-NO_QTY).
  cycleId    Int?
  remarks    String?         @db.Text
  status     SalesBillStatus @default(DRAFT)

  /// Snapshots / traceability
  customerNameSnapshot      String    @default("") @db.VarChar(256)
  customerStateNameSnapshot String    @default("") @db.VarChar(128)
  customerStateCodeSnapshot String    @default("") @db.VarChar(2)
  billToAddressSnapshot     String    @default("") @db.Text
  billToGstinSnapshot       String    @default("") @db.VarChar(15)
  shipToLabelSnapshot       String    @default("") @db.VarChar(128)
  shipToAddressSnapshot     String    @default("") @db.Text
  shipToGstinSnapshot       String    @default("") @db.VarChar(15)
  shipToStateNameSnapshot   String    @default("") @db.VarChar(128)
  shipToStateCodeSnapshot   String    @default("") @db.VarChar(2)
  posStateNameSnapshot      String    @default("") @db.VarChar(128)
  posStateCodeSnapshot      String    @default("") @db.VarChar(2)
  posSourceSnapshot         String    @default("") @db.VarChar(32)
  dispatchNoSnapshot        String    @default("") @db.VarChar(64)
  dispatchDateSnapshot      DateTime?
  soIdSnapshot              Int?

  /// Export lock (mirrors PurchaseBill)
  isExported        Boolean   @default(false)
  exportedAt        DateTime?
  exportedFileName  String?   @db.VarChar(255)
  exportedById      Int?
  exportResetAt     DateTime?
  exportResetReason String?   @db.Text
  exportResetById   Int?

  /// Finalize/cancel audit
  finalizedAt   DateTime?
  finalizedById Int?
  cancelledAt   DateTime?
  cancelledById Int?
  cancelReason  String?   @db.Text

  totalBasic Decimal @default(0) @db.Decimal(18, 2)
  totalCgst  Decimal @default(0) @db.Decimal(18, 2)
  totalSgst  Decimal @default(0) @db.Decimal(18, 2)
  totalIgst  Decimal @default(0) @db.Decimal(18, 2)
  totalTax   Decimal @default(0) @db.Decimal(18, 2)
  netAmount  Decimal @default(0) @db.Decimal(18, 2)

  /// Commercial payment follow-up (Tally is ledger of record).
  paymentStatus  BillPaymentTrackingStatus @default(PENDING)
  dueDate        DateTime?                 @db.Date
  receivedAmount Decimal                   @default(0) @db.Decimal(18, 2)
  pendingAmount  Decimal                   @default(0) @db.Decimal(18, 2)
  paymentRemarks String?                   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  dispatch Dispatch         @relation(fields: [dispatchId], references: [id], onDelete: Restrict)
  cycle    SalesOrderCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  lines    SalesBillLine[]
  receipts SalesBillReceipt[]

  exportResetBy User? @relation("SalesBillExportResetBy", fields: [exportResetById], references: [id], onDelete: SetNull)
  exportedBy    User? @relation("SalesBillExportedBy", fields: [exportedById], references: [id], onDelete: SetNull)
  finalizedBy   User? @relation("SalesBillFinalizedBy", fields: [finalizedById], references: [id], onDelete: SetNull)
  cancelledBy   User? @relation("SalesBillCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  @@index([billDate])
  @@index([status])
  @@index([customerId])
  @@index([dispatchId])
  @@index([cycleId])
  @@index([isExported])
  @@index([exportedById])
  @@index([exportResetById])
  @@index([finalizedById])
  @@index([cancelledById])
}

/// Commercial receipt lines against a sales bill (sum drives receivedAmount).
model SalesBillReceipt {
  id           Int                   @id @default(autoincrement())
  salesBillId  Int
  receiptDate  DateTime              @db.Date
  amount       Decimal               @db.Decimal(18, 2)
  mode         CommercialPaymentMode
  referenceNo  String?               @db.VarChar(128)
  remarks      String?               @db.Text
  createdById  Int?
  createdAt    DateTime              @default(now())

  salesBill SalesBill @relation(fields: [salesBillId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("SalesBillReceiptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([salesBillId])
  @@index([receiptDate])
}

model SalesBillLine {
  id          Int  @id @default(autoincrement())
  salesBillId Int
  dispatchId  Int?
  soId        Int?
  itemId      Int

  itemNameSnapshot String  @default("") @db.VarChar(256)
  hsnCodeSnapshot  String  @default("") @db.VarChar(32)
  unitSnapshot     String  @default("") @db.VarChar(64)
  qty              Decimal @db.Decimal(18, 3)
  rate             Decimal @db.Decimal(18, 4)
  basicAmount      Decimal @db.Decimal(18, 2)
  gstRate          Decimal @db.Decimal(5, 2)
  cgstAmount       Decimal @db.Decimal(18, 2)
  sgstAmount       Decimal @db.Decimal(18, 2)
  igstAmount       Decimal @db.Decimal(18, 2)
  lineTotal        Decimal @db.Decimal(18, 2)

  /// NO_QTY billing from approved rate contract: snapshot of contract `effectiveFrom`. Null for REGULAR SO lines.
  rateEffectiveFrom DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesBill SalesBill @relation(fields: [salesBillId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([salesBillId])
  @@index([itemId])
  @@index([dispatchId])
  @@index([soId])
}

model RmPurchaseOrder {
  id                        Int        @id @default(autoincrement())
  supplierId                Int
  /// Supply location (branch/depot) for commercial source — not warehouse receiving.
  supplierLocationId        Int?
  status                    RmPoStatus @default(PENDING)
  remarks                   String?    @db.Text
  /// Supplier state snapshot at PO time (GST / Tally); optional for legacy rows.
  supplierStateSnapshot     String?    @db.VarChar(128)
  /// Supplier GST state code snapshot (2-digit); optional for legacy rows.
  supplierStateCodeSnapshot String?    @db.VarChar(2)
  /// Registered supplier snapshots (frozen at PO create).
  supplierNameSnapshot                 String? @db.VarChar(256)
  supplierRegisteredGstinSnapshot      String? @db.VarChar(15)
  supplierRegisteredAddressSnapshot    String? @db.Text
  supplierRegisteredStateNameSnapshot  String? @db.VarChar(128)
  supplierRegisteredStateCodeSnapshot  String? @db.VarChar(2)
  /// Supply location snapshots (frozen at PO create).
  supplyLocationLabelSnapshot          String? @db.VarChar(128)
  supplyLocationAddressSnapshot        String? @db.Text
  supplyLocationGstinSnapshot          String? @db.VarChar(15)
  supplyLocationStateNameSnapshot      String? @db.VarChar(128)
  supplyLocationStateCodeSnapshot      String? @db.VarChar(2)
  /// Purchase tax source state (for GST mode; bill phase uses later).
  purchaseSourceStateNameSnapshot        String? @db.VarChar(128)
  purchaseSourceStateCodeSnapshot        String? @db.VarChar(2)
  purchaseSourceSnapshot                 String? @db.VarChar(32)
  purchaseGstModeSnapshot                String? @db.VarChar(32)
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt

  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierLocation SupplierLocation? @relation(fields: [supplierLocationId], references: [id], onDelete: SetNull)
  lines            RmPurchaseOrderLine[]
  grns             Grn[]

  @@index([supplierId])
  @@index([supplierLocationId])
  @@index([status])
}

model RmPurchaseOrderLine {
  id      Int      @id @default(autoincrement())
  rmPoId  Int
  itemId  Int
  qty     Decimal  @db.Decimal(18, 3)
  rate    Decimal  @default(0) @db.Decimal(18, 2)
  /// Unit text snapshot from item master at PO time.
  unit    String?  @db.VarChar(64)
  /// HSN snapshot from item master at PO time.
  hsn     String?  @db.VarChar(32)
  /// GST % snapshot from item master at PO time.
  gstRate Decimal? @db.Decimal(5, 2)
  /// qty × rate, persisted for exports / bills.
  amount  Decimal? @db.Decimal(18, 2)

  rmPo     RmPurchaseOrder @relation(fields: [rmPoId], references: [id], onDelete: Cascade)
  item     Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  grnLines GrnLine[]
  procurementLinks RmPoLineProcurementLink[]

  @@index([rmPoId])
}

model Grn {
  id             Int              @id @default(autoincrement())
  rmPoId         Int
  /// Denormalized from RM PO at receipt time; used with supplierInvoiceNo for duplicate checks.
  supplierId     Int
  /// Commercial supply location inherited from RM PO (not warehouse receiving location).
  supplierLocationId Int?
  /// Supplier invoice / bill number on this GRN receipt (required for new GRNs).
  supplierInvoiceNo String          @db.VarChar(128)
  date           DateTime         @default(now())
  reversedAt     DateTime?
  reversalReason String?          @db.Text
  billingStatus  GrnBillingStatus @default(PENDING)

  rmPo             RmPurchaseOrder  @relation(fields: [rmPoId], references: [id], onDelete: Cascade)
  supplier         Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierLocation SupplierLocation? @relation(fields: [supplierLocationId], references: [id], onDelete: SetNull)
  lines            GrnLine[]
  /// Purchase bills created from this GRN (may be multiple with partial billing).
  purchaseBills PurchaseBill[]

  @@index([rmPoId])
  @@index([supplierId, supplierInvoiceNo])
  @@index([supplierLocationId])
  @@index([date])
  @@index([reversedAt])
  @@index([billingStatus])
}

model GrnLine {
  id           Int     @id @default(autoincrement())
  grnId        Int
  rmPoLineId   Int
  receivedQty  Decimal @db.Decimal(18, 3)
  /// Snapshot: agreed purchase rate copied from RM PO line at receipt time.
  rateSnapshot Decimal @default(0) @db.Decimal(18, 4)
  /// Receiving location (godown) — required for new GRNs; nullable for legacy rows.
  locationId   Int?

  grn               Grn                 @relation(fields: [grnId], references: [id], onDelete: Cascade)
  rmPoLine          RmPurchaseOrderLine @relation(fields: [rmPoLineId], references: [id], onDelete: Cascade)
  location          Location?           @relation(fields: [locationId], references: [id], onDelete: Restrict)
  purchaseBillLines PurchaseBillLine[]

  @@index([grnId])
  @@index([rmPoLineId])
  @@index([locationId])
}

/// Supplier purchase invoice against one GRN (no stock movement).
model PurchaseBill {
  id                        Int                @id @default(autoincrement())
  /// Supplier invoice / bill number (required to finalize).
  billNo                    String?            @db.VarChar(128)
  billDate                  DateTime           @db.Date
  dueDate                   DateTime?          @db.Date
  supplierId                Int
  /// Optional: this bill may be created against multiple GRNs (flow: GRN lines selection).
  /// For backward compatibility, existing bills still store a primary GRN reference.
  grnId                     Int?
  remarks                   String?            @db.Text
  status                    PurchaseBillStatus @default(DRAFT)
  /// True once Tally XML export is performed (locks export/delete until admin reset).
  isExported                Boolean            @default(false)
  exportedAt                DateTime?
  exportedFileName          String?            @db.VarChar(255)
  exportResetAt             DateTime?
  exportResetReason         String?            @db.Text
  exportResetById           Int?
  totalBasic                Decimal            @default(0) @db.Decimal(18, 2)
  totalCgst                 Decimal            @default(0) @db.Decimal(18, 2)
  totalSgst                 Decimal            @default(0) @db.Decimal(18, 2)
  totalIgst                 Decimal            @default(0) @db.Decimal(18, 2)
  totalTax                  Decimal            @default(0) @db.Decimal(18, 2)
  netAmount                 Decimal            @default(0) @db.Decimal(18, 2)
  /// Commercial payment follow-up (Tally is ledger of record).
  paymentStatus  BillPaymentTrackingStatus @default(PENDING)
  paidAmount     Decimal                   @default(0) @db.Decimal(18, 2)
  pendingAmount  Decimal                   @default(0) @db.Decimal(18, 2)
  finalizedAt               DateTime?
  cancelledAt               DateTime?
  cancelReason              String?            @db.Text
  cancelledById             Int?
  /// Supplier state snapshots (optional; used for GST/tally stability in testing mode).
  supplierStateSnapshot     String?            @db.VarChar(128)
  supplierStateCodeSnapshot String?            @db.VarChar(2)
  /// Registered supplier commercial snapshots (frozen at bill creation).
  supplierNameSnapshot                 String @default("") @db.VarChar(256)
  supplierRegisteredGstinSnapshot      String @default("") @db.VarChar(15)
  supplierRegisteredAddressSnapshot    String @default("") @db.Text
  supplierRegisteredStateNameSnapshot  String @default("") @db.VarChar(128)
  supplierRegisteredStateCodeSnapshot  String @default("") @db.VarChar(2)
  /// Supply location commercial snapshots (frozen at bill creation).
  supplyLocationLabelSnapshot        String @default("") @db.VarChar(128)
  supplyLocationAddressSnapshot      String @default("") @db.Text
  supplyLocationGstinSnapshot        String @default("") @db.VarChar(15)
  supplyLocationStateNameSnapshot    String @default("") @db.VarChar(128)
  supplyLocationStateCodeSnapshot    String @default("") @db.VarChar(2)
  /// Purchase source / GST mode snapshots (frozen at bill creation).
  purchaseSourceStateNameSnapshot String @default("") @db.VarChar(128)
  purchaseSourceStateCodeSnapshot String @default("") @db.VarChar(2)
  purchaseSourceSnapshot          String @default("") @db.VarChar(32)
  purchaseGstModeSnapshot         String @default("") @db.VarChar(32)
  /// True when bill used relaxed fallback values (testing mode) at any point.
  hasTemporaryTaxData       Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  supplier      Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  grn           Grn?               @relation(fields: [grnId], references: [id], onDelete: SetNull)
  lines         PurchaseBillLine[]
  payments      PurchaseBillPayment[]
  exportResetBy User?              @relation("PurchaseBillExportResetBy", fields: [exportResetById], references: [id], onDelete: SetNull)
  cancelledBy   User?              @relation("PurchaseBillCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([grnId])
  @@index([billDate])
  @@index([status])
  @@index([isExported])
  @@index([exportResetById])
  @@index([cancelledById])
}

/// Commercial payment lines against a purchase bill (sum drives paidAmount).
model PurchaseBillPayment {
  id             Int                   @id @default(autoincrement())
  purchaseBillId Int
  paymentDate    DateTime              @db.Date
  amount         Decimal               @db.Decimal(18, 2)
  mode           CommercialPaymentMode
  referenceNo    String?               @db.VarChar(128)
  remarks        String?               @db.Text
  createdById    Int?
  createdAt      DateTime              @default(now())

  purchaseBill PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("PurchaseBillPaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([purchaseBillId])
  @@index([paymentDate])
}

model PurchaseBillLine {
  id               Int     @id @default(autoincrement())
  purchaseBillId   Int
  itemId           Int
  /// Source references (traceability + eligibility enforcement).
  grnId            Int?
  grnLineId        Int?
  rmPoId           Int?
  rmPoLineId       Int?
  /// Snapshot: item name at billing time (for stable exports).
  itemNameSnapshot String  @default("") @db.VarChar(256)
  qty              Decimal @db.Decimal(18, 3)
  unitSnapshot     String  @db.VarChar(64)
  /// Snapshot: HSN/SAC at billing time (for stable exports).
  hsnCodeSnapshot  String  @default("") @db.VarChar(32)
  rate             Decimal @db.Decimal(18, 4)
  basicAmount      Decimal @db.Decimal(18, 2)
  gstRate          Decimal @db.Decimal(5, 2)
  cgstAmount       Decimal @db.Decimal(18, 2)
  sgstAmount       Decimal @db.Decimal(18, 2)
  igstAmount       Decimal @db.Decimal(18, 2)
  lineTotal        Decimal @db.Decimal(18, 2)

  purchaseBill PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  grnLine      GrnLine?     @relation(fields: [grnLineId], references: [id], onDelete: SetNull)

  @@index([purchaseBillId])
  @@index([itemId])
  @@index([grnLineId])
  @@index([grnId])
  @@index([rmPoId])
}

model WorkOrder {
  id                      Int          @id @default(autoincrement())
  /// Display document number (e.g. WO-24-0001). Auto-generated on create.
  docNo                   String?      @unique @db.VarChar(32)
  /// Every work order must belong to a sales order (DB NOT NULL; see cleanup + migration if upgrading legacy DBs).
  salesOrderId            Int
  /// NO_QTY: workflow cycle isolation (null for legacy / regular flows).
  cycleId                 Int?
  /// NO_QTY flow: when created from a locked requirement sheet version, link to prevent duplicates.
  requirementSheetId      Int?         @unique
  status                  SimpleStatus @default(PENDING)
  /// REGULAR: operational hold (does not change line qty or produced qty).
  holdReason              WoHoldReason?
  heldAt                  DateTime?
  heldByUserId            Int?
  holdRemarks             String?      @db.Text
  /// Sum of line shortfalls when status = CLOSED_WITH_SHORTFALL (original line qty unchanged).
  shortfallQty            Decimal?     @db.Decimal(18, 3)
  closureReason           String?      @db.Text
  closedAt                DateTime?
  closedByUserId          Int?
  /// Admin-only override reason when WO is created despite sufficient usable FG stock.
  fgStockOverrideReason   String?      @db.Text
  fgStockOverrideAt       DateTime?
  fgStockOverrideByUserId Int?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  heldBy                          User?                            @relation("WoHeldBy", fields: [heldByUserId], references: [id], onDelete: SetNull)
  closedBy                        User?                            @relation("WoClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  salesOrder                      SalesOrder                       @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  cycle                           SalesOrderCycle?                 @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  lines                           WorkOrderLine[]
  materialAllocations             MaterialAllocation[]
  scrapLoss                       ScrapRecord[]
  requirementSheet                RequirementSheet?                @relation(fields: [requirementSheetId], references: [id], onDelete: SetNull)
  fgStockOverrideBy               User?                            @relation("WoFgStockOverrideBy", fields: [fgStockOverrideByUserId], references: [id], onDelete: SetNull)
  qcRejectedDispositions          QcRejectedDisposition[]
  qcLegacyRejectedClassifications QcLegacyRejectedClassification[]
  materialIssueNotes              MaterialIssueNote[]
  productionMaterialRequests      ProductionMaterialRequest[]
  materialReturnNotes             MaterialReturnNote[]
  materialWastageNotes            MaterialWastageNote[]
  materialRequirements            MaterialRequirement[]

  @@index([status])
  @@index([salesOrderId])
  @@index([cycleId])
  @@index([fgStockOverrideByUserId])
}

model SalesOrderCycle {
  id           Int                   @id @default(autoincrement())
  salesOrderId Int
  cycleNo      Int
  status       SalesOrderCycleStatus @default(ACTIVE)
  createdAt    DateTime              @default(now())
  closedAt     DateTime?

  /// Captured when a new cycle is created due to reopen (cycleNo >= 2). Null for cycle 1.
  reopenReason     String? @db.Text
  reopenedByUserId Int?

  salesOrder           SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  reopenedBy           User?       @relation("SalesOrderCycleReopenedBy", fields: [reopenedByUserId], references: [id], onDelete: SetNull)
  currentForSalesOrder SalesOrder? @relation("SalesOrderCurrentCycle")

  /// NO_QTY only: operator chose to treat remaining usable FG as optional store stock — suppresses operational dispatch dashboard pressure only (no stock math change).
  noQtyTreatFgAsOptionalStoreStock Boolean @default(false)

  dispatchRows      Dispatch[]
  requirementSheets RequirementSheet[]
  workOrders        WorkOrder[]
  salesBills        SalesBill[]

  @@unique([salesOrderId, cycleNo])
  @@index([salesOrderId])
  @@index([status])
}

model WorkOrderLine {
  id          Int     @id @default(autoincrement())
  workOrderId Int
  fgItemId    Int
  /// Required FG quantity committed against the sales order (dispatch and SO validation use this).
  qty         Decimal @db.Decimal(18, 3)
  /// Production target for this line; may exceed `qty` for QC/reject buffer. Production is capped here.
  plannedQty  Decimal @db.Decimal(18, 3)
  /// Set when WO is CLOSED_WITH_SHORTFALL: max(0, qty − approved produced) at close time.
  shortfallQty Decimal? @db.Decimal(18, 3)

  workOrder   WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fgItem      Item              @relation("WoLineFg", fields: [fgItemId], references: [id], onDelete: Restrict)
  productions ProductionEntry[]
  materialAllocations MaterialAllocation[]

  @@index([workOrderId])
  @@index([fgItemId])
}

model ProductionEntry {
  id              Int                           @id @default(autoincrement())
  /// Display document number (e.g. PE-24-0001). Auto-generated on create.
  docNo           String?                       @unique @db.VarChar(32)
  workOrderLineId Int
  producedQty     Decimal                       @db.Decimal(18, 3)
  date            DateTime                      @default(now())
  /// DRAFT: editable; no RM stock issue; excluded from QC queue. APPROVED: locked; RM issued; eligible for QC.
  workflowStatus  ProductionEntryWorkflowStatus @default(DRAFT)

  workOrderLine   WorkOrderLine                  @relation(fields: [workOrderLineId], references: [id], onDelete: Cascade)
  qcEntries       QcEntry[]
  rmConsumptions  ProductionEntryRmConsumption[]

  @@index([workOrderLineId])
  @@index([date])
  @@index([workflowStatus])
}

/// Immutable RM standard vs actual snapshot per approved production batch (REGULAR).
model ProductionEntryRmConsumption {
  id                Int                @id @default(autoincrement())
  productionEntryId Int
  itemId            Int
  standardQty       Decimal            @db.Decimal(18, 3)
  actualQty         Decimal            @db.Decimal(18, 3)
  varianceQty       Decimal            @db.Decimal(18, 3)
  variancePercent   Decimal?           @db.Decimal(18, 3)
  consumptionType   RmConsumptionType?
  remarks           String?            @db.Text
  createdAt         DateTime           @default(now())

  productionEntry ProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([productionEntryId, itemId], map: "PeRmConsumption_peId_itemId_key")
  @@index([productionEntryId])
  @@index([itemId])
}

model QcEntry {
  id                  Int              @id @default(autoincrement())
  /// Display document number (e.g. QC-24-0001). Auto-generated on create.
  docNo               String?          @unique @db.VarChar(32)
  productionId        Int
  acceptedQty         Decimal          @db.Decimal(18, 3)
  rejectedQty         Decimal          @db.Decimal(18, 3)
  /// When rejectedQty is positive, ledger posts rejected units into this bucket (USABLE = re-approved immediately).
  /// Rows with null bucket before migration 20260410150000 were backfilled to QC_HOLD (Hold for Checking); see QcEntry.reason prefix `[legacy QC_HOLD]`.
  rejectedStockBucket StockBucket?
  /// Operator routing for rejected qty (Rework vs Hold vs Scrap vs immediate Usable). Null on legacy rows.
  rejectedRoute       QcRejectedRoute?
  reason              String?
  scrapReusable       Boolean          @default(false)
  lossQty             Decimal          @db.Decimal(18, 3)
  date                DateTime         @default(now())
  /// When set, this QC is voided; a new QC may be posted for the same production.
  reversedAt          DateTime?
  reversalReason      String?

  production                   ProductionEntry                 @relation(fields: [productionId], references: [id], onDelete: Cascade)
  reversal                     QcReversal?
  scrapRecords                 ScrapRecord[]
  rejectedDispositions         QcRejectedDisposition[]         @relation("RejectedDispositionSourceQc")
  legacyRejectedClassification QcLegacyRejectedClassification?

  @@index([productionId])
  @@index([date])
}

/// Traceable lot for rejected QC quantity: rework approval, hold, scrap, and QC recheck branching.
model QcRejectedDisposition {
  id                         Int                         @id @default(autoincrement())
  sourceQcEntryId            Int
  workOrderId                Int
  itemId                     Int
  qty                        Decimal                     @db.Decimal(18, 3)
  remainingQty               Decimal                     @db.Decimal(18, 3)
  phase                      QcRejectedPhase             @default(FIRST_QC)
  status                     QcRejectedDispositionStatus
  remarks                    String?                     @db.Text
  createdByUserId            Int?
  supervisorApprovedByUserId Int?
  supervisorApprovedAt       DateTime?
  supervisorDeniedAt         DateTime?
  closedAt                   DateTime?
  voidedAt                   DateTime?
  parentDispositionId        Int?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  sourceQcEntry        QcEntry                 @relation("RejectedDispositionSourceQc", fields: [sourceQcEntryId], references: [id], onDelete: Cascade)
  workOrder            WorkOrder               @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  item                 Item                    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy            User?                   @relation("QcRejDispCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  supervisorApprovedBy User?                   @relation("QcRejDispSupervisorApproved", fields: [supervisorApprovedByUserId], references: [id], onDelete: SetNull)
  parentDisposition    QcRejectedDisposition?  @relation("DispositionSplit", fields: [parentDispositionId], references: [id], onDelete: SetNull)
  childDispositions    QcRejectedDisposition[] @relation("DispositionSplit")
  stockTransactions    StockTransaction[]

  @@index([sourceQcEntryId])
  @@index([workOrderId])
  @@index([itemId])
  @@index([status])
  @@index([voidedAt])
}

/// Classifies legacy (pre–rejectedRoute) production QC rejected qty once: moves stock between buckets without editing QcEntry.
model QcLegacyRejectedClassification {
  id              Int                    @id @default(autoincrement())
  sourceQcEntryId Int                    @unique
  workOrderId     Int?
  itemId          Int
  qty             Decimal                @db.Decimal(18, 3)
  action          QcLegacyRejectedAction
  /// Snapshot of bucket the original QC reject posting used (null treated as QC_HOLD for stock resolution).
  fromStockBucket StockBucket?
  /// Bucket after classification (matches action intent).
  toStockBucket   StockBucket?
  remarks         String?                @db.Text
  createdByUserId Int
  createdAt       DateTime               @default(now())
  voidedAt        DateTime?

  sourceQcEntry QcEntry    @relation(fields: [sourceQcEntryId], references: [id], onDelete: Restrict)
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  item          Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy     User       @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([itemId])
  @@index([createdAt])
}

/// One full reversal per QC entry; stock QC_REVERSAL rows use refId = this id.
model QcReversal {
  id        Int      @id @default(autoincrement())
  qcEntryId Int      @unique
  reason    String?
  createdAt DateTime @default(now())

  qcEntry QcEntry @relation(fields: [qcEntryId], references: [id], onDelete: Cascade)

  @@index([qcEntryId])
}

/// Scrap/Loss tracking only (NOT stock). Auto-created from QC when rejectedQty > 0.
model ScrapRecord {
  id          Int       @id @default(autoincrement())
  fgItemId    Int
  workOrderId Int
  rejectedQty Decimal   @db.Decimal(18, 3)
  reason      String?
  date        DateTime  @default(now())
  voidedAt    DateTime?
  qcEntryId   Int?

  fgItem    Item      @relation("ScrapFgItem", fields: [fgItemId], references: [id], onDelete: Restrict)
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  qcEntry   QcEntry?  @relation(fields: [qcEntryId], references: [id], onDelete: SetNull)

  @@index([fgItemId, date])
  @@index([workOrderId])
  @@index([qcEntryId])
}

/// Inventory location master (RM Store, Production, FG Store, etc.).
model Location {
  id               Int                @id @default(autoincrement())
  /// Auto-generated code (e.g. LOC-RM-STORE).
  locationCode     String             @unique @db.VarChar(32)
  locationName     String             @db.VarChar(128)
  locationType     LocationType
  departmentOwner  LocationDepartment
  allowRm          Boolean            @default(false)
  allowFg          Boolean            @default(false)
  allowSfg         Boolean            @default(false)
  allowConsumable  Boolean            @default(false)
  isActive         Boolean            @default(true)
  /// System-seeded defaults — cannot delete.
  isSystem         Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  stockTransactions     StockTransaction[]
  grnLines              GrnLine[]
  materialIssuesFrom    MaterialIssueNote[] @relation("MaterialIssueFromLocation")
  materialIssuesTo      MaterialIssueNote[] @relation("MaterialIssueToLocation")
  materialReturnsFrom   MaterialReturnNote[] @relation("MaterialReturnFromLocation")
  materialReturnsTo     MaterialReturnNote[] @relation("MaterialReturnToLocation")
  materialWastageFrom   MaterialWastageNote[] @relation("MaterialWastageFromLocation")
  materialAllocations   MaterialAllocation[]

  @@index([locationType])
  @@index([isActive])
}

model StockTransaction {
  id                      Int          @id @default(autoincrement())
  itemId                  Int
  /// Nullable for legacy rows; reads treat null as default RM Store until fully migrated.
  locationId              Int?
  transactionType         StockTxnType
  refId                   Int
  /// Optional linkage for disposition-owned rework QC (prevents pooled consumption across WOs).
  qcRejectedDispositionId Int?
  /// Inventory bucket classification (do not mix QC_HOLD/REWORK into usable stock).
  stockBucket             StockBucket  @default(USABLE)
  qtyIn                   Decimal      @default(0) @db.Decimal(18, 3)
  qtyOut                  Decimal      @default(0) @db.Decimal(18, 3)
  /// Free-text reason for ADJUSTMENT rows (required on new API posts; null for legacy rows).
  reason                  String?      @db.Text
  date                    DateTime     @default(now())

  createdByUserId  Int?
  approvedByUserId Int?
  reversalOfId     Int?
  reversedAt       DateTime?
  reversedByUserId Int?

  item                     Item                     @relation(fields: [itemId], references: [id], onDelete: Restrict)
  location                 Location?                @relation(fields: [locationId], references: [id], onDelete: Restrict)
  qcRejectedDisposition    QcRejectedDisposition?   @relation(fields: [qcRejectedDispositionId], references: [id], onDelete: SetNull)
  createdBy                User?                    @relation("StockTxnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy               User?                    @relation("StockTxnApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  reversedBy               User?                    @relation("StockTxnReversedBy", fields: [reversedByUserId], references: [id], onDelete: SetNull)
  reversalParent           StockTransaction?        @relation("AdjustmentReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversalChildren         StockTransaction[]       @relation("AdjustmentReversal")
  stockAdjustmentQcEntries StockAdjustmentQcEntry[]

  @@index([itemId, date])
  @@index([locationId, itemId, stockBucket])
  @@index([transactionType, refId])
  @@index([stockBucket, itemId])
  @@index([qcRejectedDispositionId, stockBucket, itemId])
  @@index([reversalOfId])
  @@index([approvedByUserId])
}

/// Masters → Opening Stock: draft rows that become StockTransaction.OPENING only on approval.
model OpeningStockEntry {
  id          Int                @id @default(autoincrement())
  itemId      Int
  stockBucket StockBucket        @default(USABLE)
  openingQty  Decimal            @db.Decimal(18, 3)
  status      OpeningStockStatus @default(DRAFT)
  remarks     String?            @db.Text

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?

  createdByUserId  Int?
  approvedByUserId Int?

  item       Item  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy  User? @relation("OpeningStockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedBy User? @relation("OpeningStockApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([status, createdAt])
  @@index([approvedAt])
}

enum CustomerReturnDisposition {
  QC_HOLD
  REWORK
  TO_STOCK
}

enum CustomerReturnStatus {
  IN_REWORK
  IN_QC_HOLD
  APPROVED_TO_STOCK
  SCRAPPED
  REVERSED
}

model CustomerReturn {
  id            Int                       @id @default(autoincrement())
  customerId    Int
  dispatchId    Int
  salesOrderId  Int
  itemId        Int
  returnedQty   Decimal                   @db.Decimal(18, 3)
  reason        String                    @db.Text
  returnDate    DateTime                  @default(now())
  disposition   CustomerReturnDisposition
  currentBucket StockBucket
  status        CustomerReturnStatus      @default(IN_QC_HOLD)
  closedAt      DateTime?
  remarks       String?                   @db.Text
  createdAt     DateTime                  @default(now())
  reversedAt    DateTime?

  customer              Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  dispatch              Dispatch    @relation(fields: [dispatchId], references: [id], onDelete: Restrict)
  salesOrder            SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  item                  Item        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  replacementSalesOrder SalesOrder? @relation("ReplacementForReturn")

  @@index([customerId, returnDate])
  @@index([dispatchId])
  @@index([salesOrderId, itemId])
  @@index([reversedAt])
}

/// QC postings for FG stock that entered via stock adjustment / legacy correction.
/// These QC rows contribute to the dispatch QC pool (SO + item), even without a production batch.
model StockAdjustmentQcEntry {
  id                 Int       @id @default(autoincrement())
  /// FK to the stock transaction that increased FG stock (typically ADJUSTMENT qtyIn > 0).
  stockTransactionId Int
  /// Which sales order this QC-cleared stock is allocated to for dispatch QC pooling.
  salesOrderId       Int
  itemId             Int
  acceptedQty        Decimal   @db.Decimal(18, 3)
  rejectedQty        Decimal   @db.Decimal(18, 3)
  reason             String?
  date               DateTime  @default(now())
  /// When set, this QC posting is voided; a new QC may be posted for the same stock txn.
  reversedAt         DateTime?
  reversalReason     String?

  stockTransaction StockTransaction @relation(fields: [stockTransactionId], references: [id], onDelete: Cascade)
  salesOrder       SalesOrder       @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item             Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([stockTransactionId])
  @@index([salesOrderId, itemId])
  @@index([date])
}

model AuditLog {
  id          Int             @id @default(autoincrement())
  createdAt   DateTime        @default(now())
  action      AuditAction
  entityType  AuditEntityType
  /// Set for all business rows; omit only for USER_SESSION (login/logout/failed login).
  entityId    String?         @db.VarChar(64)
  actorUserId Int?
  actorRole   String?         @db.VarChar(32)
  summary     String          @db.VarChar(512)
  payload     Json?
  reason      String?         @db.VarChar(512)
  ipAddress   String?         @db.VarChar(45)
  userAgent   String?         @db.VarChar(256)

  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([createdAt])
}

/// Phase 1 business-facing activity trail (human messages; separate from AuditLog).
model ActivityLog {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  userId           Int?
  userNameSnapshot String?  @db.VarChar(256)
  module           String   @db.VarChar(64)
  entityType       String   @db.VarChar(64)
  entityId         Int?
  docNo            String?  @db.VarChar(64)
  action           String   @db.VarChar(64)
  subAction        String?  @db.VarChar(64)
  message          String   @db.VarChar(512)
  reason           String?  @db.Text
  metadataJson     Json?
  createdByRole    String?  @db.VarChar(32)

  user User? @relation("ActivityLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([docNo])
  @@index([userId, createdAt])
}

/// Per-(DocType, year2) running sequence for docNo generation.
/// nextNumber is the next number to allocate (1-based).
model DocSequence {
  id         Int     @id @default(autoincrement())
  docType    DocType
  year2      Int
  nextNumber Int

  @@unique([docType, year2])
  @@index([docType, year2])
}
